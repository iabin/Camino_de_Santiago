  </wpt>
  <wpt lat="42.905" lon="-8.439">
    <ele>310</ele>
    <name>⛪ Ermita de Santa Irene</name>
    <desc>Km 114 — Small hermitage on the final stretch.</desc>
    <sym>Church</sym>
