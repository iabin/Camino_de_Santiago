  </wpt>
  <wpt lat="42.92" lon="-8.3">
    <ele>370</ele>
    <name>⛲ Fonte Santa Irene</name>
    <desc>Km 95 — Ancient fountain with supposedly healing waters.</desc>
    <sym>Water Source</sym>
