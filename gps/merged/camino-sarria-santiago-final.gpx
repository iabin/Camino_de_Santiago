  </wpt>
  <wpt lat="42.88069" lon="-8.54532">
    <ele>260</ele>
    <name>⭐ SANTIAGO DE COMPOSTELA — Catedral</name>
    <desc>Km 125.4 · Apr 5 · Arrived 14:19 · 30,396 steps today · 174,185 total · Fastest day (4.5 km/h moving, 10.8 min fastest km). Praza do Obradoiro. Ultreia.</desc>
    <sym>Flag, Blue</sym>
    <type>Finish</type>
  </wpt>
