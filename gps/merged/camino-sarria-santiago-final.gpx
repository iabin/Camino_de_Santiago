    <sym>Cemetery</sym>
    <type>Monument</type>
  </wpt>
  <wpt lat="42.9125" lon="-8.424">
    <ele>340</ele>
    <name>🔀 O Empalme</name>
    <desc>Km 111 — 'The Junction'. Last major crossroads before Santiago.</desc>
    <sym>Crossing</sym>
