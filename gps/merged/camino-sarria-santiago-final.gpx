    <type>Landscape</type>
  </wpt>
  <wpt lat="42.90664" lon="-8.35945">
    <ele>273</ele>
    <name>🛏️ NIGHT 4 — O Pedrouzo (Arca)</name>
    <desc>Km 103.5 · Arrived 16:05 · 35,603 steps · Moving pace 13.8 min/km · 21% rest · Last sleep. 21.9 km to the Cathedral. Set the alarm.</desc>
    <sym>Lodge</sym>
    <type>Sleep</type>
  </wpt>
  <wpt lat="42.911" lon="-8.4144">
    <ele>358</ele>
    <name>🪦 Monumento a Guillermo Watt</name>
