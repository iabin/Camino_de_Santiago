  </wpt>
  <wpt lat="42.84573" lon="-7.75542">
    <ele>679</ele>
    <name>🔺 Alto de Rosario — 679m (ROUTE HIGH POINT)</name>
    <desc>Km 38.2 — The roof of the last 100 km. Everything descends toward Santiago from here.</desc>
    <sym>Summit</sym>
    <type>Summit</type>
  </wpt>
  <wpt lat="42.87275" lon="-7.86726">
    <ele>528</ele>
    <name>🛏️ NIGHT 2 — Palas de Rei</name>
    <desc>Km 49.5 · Arrived 17:24 · 36,113 steps · Moving pace 14.8 min/km · 24% rest · Hardest climb day (+642m) · Slowest km: 79 min (lunch break segment).</desc>
    <sym>Lodge</sym>
    <type>Sleep</type>
  </wpt>
  <wpt lat="42.879" lon="-7.922">
    <ele>416</ele>
    <name>🏰 Castelo de Pambre</name>
    <desc>Km 55 — Only castle to survive the Irmandiño revolts (1467). Best-preserved in Galicia.</desc>
    <sym>Building</sym>
    <type>Castle</type>
  </wpt>
  <wpt lat="42.915" lon="-8.015">
    <ele>418</ele>
    <name>🐙 Melide — Pulpería Ezequiel</name>
    <desc>Km 63 — Pulpo á feira capital. Where the Camino Primitivo joins.</desc>
    <sym>Restaurant</sym>
    <type>Food</type>
  </wpt>
  <wpt lat="42.9155" lon="-8.013">
    <ele>416</ele>
    <name>⛪ Iglesia de Santa María de Melide</name>
    <desc>Km 63.2 — Romanesque church with rare medieval frescoes.</desc>
    <sym>Church</sym>
    <type>Church</type>
  </wpt>
  <wpt lat="42.93" lon="-8.124">
    <ele>320</ele>
    <name>🌊 Río Iso — Medieval Bridge</name>
