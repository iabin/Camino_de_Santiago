  </wpt>
  <wpt lat="42.919" lon="-8.305">
    <ele>365</ele>
    <name>⛪ Capilla de Santa Irene</name>
    <desc>Km 95.5 — Forest clearing chapel surrounded by eucalyptus.</desc>
    <sym>Church</sym>
    <type>Church</type>
  </wpt>
  <wpt lat="42.912" lon="-8.34">
    <ele>290</ele>
    <name>🌲 Eucalyptus Corridor</name>
    <desc>Km 100 — Dense eucalyptus plantation. Controversial but atmospheric.</desc>
